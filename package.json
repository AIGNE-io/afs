{
  "name": "afs",
  "description": "Explore and manage AFS file systems",
  "version": "1.11.0-beta.13",
  "license": "BUSL-1.1",
  "private": true,
  "author": "Arcblock <blocklet@arcblock.io> https://github.com/arcblock",
  "homepage": "https://github.com/arcblock/afs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcblock/afs"
  },
  "bugs": {
    "url": "https://github.com/arcblock/afs/issues"
  },
  "scripts": {
    "build": "turbo run build && bun scripts/gen-agent-md.ts",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "check-types": "turbo run check-types",
    "format": "biome check --write",
    "lint": "biome check && turbo run check-types",
    "clean": "turbo run clean",
    "postinstall": "npx -y simple-git-hooks",
    "bench": "pnpm --filter @aigne/afs-benchmarks bench",
    "bench:core": "pnpm --filter @aigne/afs-benchmarks bench:core",
    "bench:e2e": "pnpm --filter @aigne/afs-benchmarks bench:e2e",
    "bench:stress": "pnpm --filter @aigne/afs-benchmarks bench:stress"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "^1.3.6",
    "@types/node": "^25.0.9",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.28.0",
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && bash scripts/check-types-staged.sh"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "engines": {
    "node": ">=20.15"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/ripgrep",
      "esbuild",
      "onnxruntime-node",
      "simple-git-hooks"
    ],
    "overrides": {
      "@arcblock/did": "^1.29.23",
      "@arcblock/jwt": "^1.29.23",
      "@arcblock/vc": "^1.29.23",
      "@hono/node-server": ">=1.19.10",
      "@isaacs/brace-expansion": ">=5.0.1",
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "@ocap/mcrypto": "^1.29.23",
      "@ocap/util": "^1.29.23",
      "@ocap/wallet": "^1.29.23",
      "@tootallnate/once": ">=3.0.1",
      "ajv": ">=8.18.0",
      "express-rate-limit": ">=8.2.2",
      "fast-xml-parser": ">=5.5.7",
      "graphql": ">=16.8.1",
      "hono": ">=4.12.7",
      "minimatch": ">=10.2.3",
      "qs": ">=6.14.2",
      "rollup": ">=4.59.0",
      "simple-git": ">=3.32.3",
      "undici": ">=7.24.0",
      "zod": "^4.0.0"
    }
  },
  "workspaces": [
    "scripts",
    "typescript-config",
    "packages/*",
    "providers/*",
    "benchmarks",
    "integration-tests"
  ]
}
