{
  "$schema": "https://biomejs.dev/schemas/2.3.13/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!!**/node_modules",
      "!!**/dist",
      "!!packages/astrochart/src",
      "!!**/widgets",
      "!!**/widget-assets",
      "!!**/test/fixtures"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "node:fs": "Use getPlatform().fs instead (see packages/core/src/platform/)",
              "node:fs/promises": "Use getPlatform().fs instead (see packages/core/src/platform/)",
              "node:path": "Use getPlatform().path or joinURL from ufo",
              "node:os": "Use getPlatform().env or process adapter instead"
            }
          }
        }
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedPrivateClassMembers": "error",
        "noUndeclaredDependencies": "error"
      },
      "suspicious": {
        "noConfusingVoidType": "off",
        "noExplicitAny": "off",
        "useIterableCallbackReturn": "off",
        "noTsIgnore": "off",
        "noTemplateCurlyInString": "off"
      },
      "complexity": {
        "noForEach": "off",
        "useLiteralKeys": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "packages/core/src/platform/**",
        "packages/provider-utils/src/path-guard.ts",
        "providers/fs/**",
        "providers/git/**",
        "providers/vault/**",
        "providers/workspace/**",
        "providers/aignehub/**",
        "providers/registry/**",
        "providers/sqlite/**",
        "packages/cli/**",
        "packages/explorer/**",
        "packages/session/**",
        "packages/testing/**",
        "providers/http/**",
        "**/test/**",
        "**/tests/**",
        "**/examples/**",
        "scripts/**",
        "integration-tests/**",
        "benchmarks/**",
        "conformance/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
