exports[`Help and Version Commands command help afs serve --help: serve-help 1`] = `
"afs serve

Start AFS server (HTTP or MCP)

Options:
      --json       Output in JSON format                               [boolean]
      --yaml       Output in YAML format                               [boolean]
      --view       Output view format
              [string] [choices: "default", "llm", "human"] [default: "default"]
      --host       Host to bind                  [string] [default: "localhost"]
      --port       Port to listen on                    [number] [default: 3000]
      --path       Base path for API                  [string] [default: "/afs"]
      --readonly   Read-only mode                     [boolean] [default: false]
      --cors       Enable CORS                        [boolean] [default: false]
      --transport  Transport: http (default), mcp-stdio, or mcp-http
           [string] [choices: "http", "mcp-stdio", "mcp-http"] [default: "http"]
  -h, --help       Show help                                           [boolean]
  -v, --version    Show version number                                 [boolean]"
`;

