exports[`Help and Version Commands command help afs ls --help: ls-help 1`] = `
"afs ls [path]

List directory contents

Options:
      --json          Output in JSON format                            [boolean]
      --yaml          Output in YAML format                            [boolean]
      --view          Output view format
              [string] [choices: "default", "llm", "human"] [default: "default"]
      --path          Path to list                       [string] [default: "/"]
      --depth         Maximum depth to list                [number] [default: 1]
  -l                  Long listing format (detailed view)
                                                      [boolean] [default: false]
  -R                  List recursively                [boolean] [default: false]
      --limit         Maximum number of entries to return               [number]
      --max-children  Maximum children per directory                    [number]
      --pattern       Glob pattern to filter entries                    [string]
  -h, --help          Show help                                        [boolean]
  -v, --version       Show version number                              [boolean]"
`;

