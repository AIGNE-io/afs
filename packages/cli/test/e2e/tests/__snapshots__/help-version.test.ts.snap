exports[`Help and Version Commands mount subcommand help afs mount add --help: mount-add-help 1`] = `
"afs mount add <path> <uri>

Add a mount

Positionals:
  path  Mount path (e.g., /src)                              [string] [required]
  uri   Provider URI (e.g., fs://./src)                      [string] [required]

Options:
      --json            Output in JSON format                          [boolean]
      --yaml            Output in YAML format                          [boolean]
      --view            Output view format
              [string] [choices: "default", "llm", "human"] [default: "default"]
      --namespace       Mount namespace                                 [string]
      --description     Mount description                               [string]
      --sensitive-args  Field names to treat as sensitive credentials    [array]
  -s, --set             Set credential key=value directly (repeatable, bypasses
                        interactive)                                     [array]
      --terminal        Use terminal readline for credential input (instead of b
                        rowser)                                        [boolean]
  -f, --force           Force re-collect credentials (ignore cached values)
                                                                       [boolean]
  -v, --version         Show version number                            [boolean]"
`;

