exports[`exec command - MCP tools tool execution view=human exec /mcp/tools/echo with message: exec-human-mcp-echo 1`] = `
"Executed: /mcp/tools/echo

{
  "content": [
    {
      "type": "text",
      "text": "Echo: Hello from E2E test"
    }
  ]
}"
`;

exports[`exec command - MCP tools tool execution view=llm exec /mcp/tools/echo with message: exec-llm-mcp-echo 1`] = `
"EXEC /mcp/tools/echo
STATUS SUCCESS
DATA {"content":[{"type":"text","text":"Echo: Hello from E2E test"}]}"
`;

exports[`exec command - MCP tools tool execution view=json exec /mcp/tools/echo with message: exec-json-mcp-echo 1`] = `
"{
  "success": true,
  "data": {
    "content": [
      {
        "type": "text",
        "text": "Echo: Hello from E2E test"
      }
    ]
  }
}"
`;

exports[`exec command - MCP tools tool help exec /mcp/tools/echo --help shows usage: exec-mcp-echo-help 1`] = `
"afs exec /mcp/tools/echo

Echoes back the input string

Action Parameters:
      --message  Message to echo                             [string] [required]

Positionals:
  executable_path  Action path to execute                    [string] [required]

Options:
      --json     Output in JSON format                                 [boolean]
      --yaml     Output in YAML format                                 [boolean]
      --view     Output view format
              [string] [choices: "default", "llm", "human"] [default: "default"]
      --args     JSON arguments: --args '{"key": "value"}'              [string]
  -h, --help     Show help                                             [boolean]
  -v, --version  Show version number                                   [boolean]"
`;
