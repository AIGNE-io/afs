exports[`ls command .actions paths view=human sqlite root actions (/sqlite/.actions): ls-human-sqlite-_actions 1`] = `
"Available actions for /sqlite:

  create_table  Create a new table in the database
  drop_table    Drop a table from the database
  rename_table  Rename a table in the database
  pragma        Execute a PRAGMA command (whitelist-restricted)
  vacuum        Compact the database file and reclaim unused space"
`;

exports[`ls command .actions paths view=human sqlite table actions (/sqlite/users/.actions): ls-human-sqlite-users-_actions 1`] = `
"Available actions for /sqlite/users:

  export         Export table data in specified format (json, csv)
  count          Get the total row count for this table
  insert         Insert a new row into the table
  add_column     Add a new column to the table
  rename_column  Rename a column in the table
  drop_column    Drop a column from the table
  create_index   Create an index on the table
  drop_index     Drop an index from the table
  query          Query rows with conditions, ordering, and pagination
  update_where   Update rows matching conditions
  delete_where   Delete rows matching conditions
  bulk_insert    Insert multiple rows at once
  import         Import data into table from JSON or CSV format"
`;

exports[`ls command .actions paths view=human sqlite row actions (/sqlite/users/1/.actions): ls-human-sqlite-users-1-_actions 1`] = `
"Available actions for /sqlite/users/1:

  duplicate  Create a copy of this row
  validate   Validate row data against schema constraints
  update     Update this row
  delete     Delete this row"
`;

