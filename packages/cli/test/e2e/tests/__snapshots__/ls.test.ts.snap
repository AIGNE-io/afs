"ACTIONS /sqlite/.actions
ACTION create_table DESCRIPTION "Create a new table in the database" SCHEMA {"type":"object","description":"Create a new SQLite table with specified columns","properties":{"name":{"type":"string","description":"Table name (alphanumeric and underscores, must start with letter)","pattern":"^[a-zA-Z][a-zA-Z0-9_]*$","minLength":1,"maxLength":128},"columns":{"type":"array","description":"Column definitions (at least one required)","minItems":1,"items":{"type":"object","description":"Column definition","properties":{"name":{"type":"string","description":"Column name (alphanumeric and underscores)","pattern":"^[a-zA-Z_][a-zA-Z0-9_]*$","minLength":1,"maxLength":128},"type":{"type":"string","description":"SQLite column type","enum":["INTEGER","TEXT","REAL","BLOB","NUMERIC","INT","TINYINT","SMALLINT","MEDIUMINT","BIGINT","UNSIGNED BIG INT","INT2","INT8","CHARACTER","VARCHAR","VARYING CHARACTER","NCHAR","NATIVE CHARACTER","NVARCHAR","CLOB","DOUBLE","DOUBLE PRECISION","FLOAT","DECIMAL","BOOLEAN","DATE","DATETIME","TIMESTAMP"],"x-affinity-mapping":{"INTEGER":["INTEGER","INT","TINYINT","SMALLINT","MEDIUMINT","BIGINT","UNSIGNED BIG INT","INT2","INT8"],"TEXT":["TEXT","CHARACTER","VARCHAR","VARYING CHARACTER","NCHAR","NATIVE CHARACTER","NVARCHAR","CLOB"],"REAL":["REAL","DOUBLE","DOUBLE PRECISION","FLOAT"],"NUMERIC":["NUMERIC","DECIMAL","BOOLEAN","DATE","DATETIME","TIMESTAMP"],"BLOB":["BLOB"]}},"nullable":{"type":"boolean","description":"Whether the column allows NULL values (default: true)","default":true},"primaryKey":{"type":"boolean","description":"Whether this column is the primary key (default: false). INTEGER PRIMARY KEY will auto-increment.","default":false},"unique":{"type":"boolean","description":"Whether this column must have unique values (default: false)","default":false},"defaultValue":{"oneOf":[{"type":"string"},{"type":"number"},{"type":"boolean"},{"type":"null"}],"description":"Default value for the column. Use string 'CURRENT_TIMESTAMP' for auto timestamp."},"references":{"type":"object","description":"Foreign key reference","properties":{"table":{"type":"string","description":"Referenced table name"},"column":{"type":"string","description":"Referenced column name"},"onDelete":{"type":"string","enum":["CASCADE","SET NULL","SET DEFAULT","RESTRICT","NO ACTION"],"description":"Action on delete (default: NO ACTION)"},"onUpdate":{"type":"string","enum":["CASCADE","SET NULL","SET DEFAULT","RESTRICT","NO ACTION"],"description":"Action on update (default: NO ACTION)"}},"required":["table","column"]}},"required":["name","type"],"additionalProperties":false}},"ifNotExists":{"type":"boolean","description":"If true, do not throw error if table already exists (default: false)","default":false}},"required":["name","columns"],"additionalProperties":false}
ACTION drop_table DESCRIPTION "Drop a table from the database" SCHEMA {"type":"object","properties":{"name":{"type":"string","description":"Table name to drop"},"ifExists":{"type":"boolean","default":false,"description":"Don't error if table doesn't exist"}},"required":["name"]}
ACTION rename_table DESCRIPTION "Rename a table in the database" SCHEMA {"type":"object","properties":{"oldName":{"type":"string","description":"Current table name"},"newName":{"type":"string","description":"New table name"}},"required":["oldName","newName"]}
ACTION pragma DESCRIPTION "Execute a PRAGMA command (whitelist-restricted)" SCHEMA {"type":"object","properties":{"command":{"type":"string","enum":["table_info","table_list","index_list","index_info","foreign_key_list","database_list","collation_list","journal_mode","synchronous","cache_size","page_size","encoding","auto_vacuum","integrity_check","quick_check"],"description":"PRAGMA command to execute"},"argument":{"type":"string","description":"Argument for the command (e.g., table name)"},"value":{"oneOf":[{"type":"string"},{"type":"number"}],"description":"Value for writable PRAGMAs"}},"required":["command"]}
ACTION vacuum DESCRIPTION "Compact the database file and reclaim unused space" SCHEMA {"type":"object","properties":{},"additionalProperties":false}"
`;

exports[`ls command .actions paths view=llm sqlite table actions (/sqlite/users/.actions): ls-llm-sqlite-users-_actions 1`] = `
"ACTIONS /sqlite/users/.actions
ACTION export DESCRIPTION "Export table data in specified format (json, csv)" SCHEMA {"type":"object","properties":{"format":{"type":"string","enum":["json","csv"],"default":"json"}}}
ACTION count DESCRIPTION "Get the total row count for this table"
ACTION insert DESCRIPTION "Insert a new row into the table" SCHEMA {"type":"object","description":"Insert a new row into \\"users\\" table","properties":{"data":{"type":"object","description":"Row data to insert","properties":{"name":{"type":"string"},"email":{"type":"string"},"created_at":{"type":"string","default":"CURRENT_TIMESTAMP","description":"Default: CURRENT_TIMESTAMP"}},"required":["name"],"additionalProperties":false}},"required":["data"]}
ACTION add_column DESCRIPTION "Add a new column to the table" SCHEMA {"type":"object","properties":{"name":{"type":"string","description":"Column name"},"type":{"type":"string","enum":["INTEGER","TEXT","REAL","BLOB","NUMERIC"],"description":"Column type"},"nullable":{"type":"boolean","default":true,"description":"Whether the column allows NULL values"},"defaultValue":{"oneOf":[{"type":"string"},{"type":"number"},{"type":"boolean"},{"type":"null"}],"description":"Default value for the column"}},"required":["name","type"]}
ACTION rename_column DESCRIPTION "Rename a column in the table" SCHEMA {"type":"object","properties":{"oldName":{"type":"string","description":"Current column name"},"newName":{"type":"string","description":"New column name"}},"required":["oldName","newName"]}
ACTION drop_column DESCRIPTION "Drop a column from the table" SCHEMA {"type":"object","properties":{"name":{"type":"string","description":"Column name to drop"}},"required":["name"]}
ACTION create_index DESCRIPTION "Create an index on the table" SCHEMA {"type":"object","properties":{"name":{"type":"string","description":"Index name"},"columns":{"type":"array","items":{"type":"string"},"minItems":1,"description":"Columns to index (supports compound indexes)"},"unique":{"type":"boolean","default":false,"description":"Whether the index is unique"},"ifNotExists":{"type":"boolean","default":false,"description":"Don't error if index already exists"}},"required":["name","columns"]}
ACTION drop_index DESCRIPTION "Drop an index from the table" SCHEMA {"type":"object","properties":{"name":{"type":"string","description":"Index name to drop"},"ifExists":{"type":"boolean","default":false,"description":"Don't error if index doesn't exist"}},"required":["name"]}
ACTION query DESCRIPTION "Query rows with conditions, ordering, and pagination" SCHEMA {"type":"object","properties":{"where":{"type":"object","description":"Query conditions (MongoDB-style operators)"},"orderBy":{"type":"array","items":{"type":"object","properties":{"column":{"type":"string"},"direction":{"type":"string","enum":["asc","desc"],"default":"asc"}},"required":["column"]},"description":"Sort order"},"limit":{"type":"integer","minimum":1,"description":"Maximum rows to return"},"offset":{"type":"integer","minimum":0,"description":"Number of rows to skip"}}}
ACTION update_where DESCRIPTION "Update rows matching conditions" SCHEMA {"type":"object","properties":{"where":{"type":"object","description":"Update conditions (MongoDB-style operators)"},"data":{"type":"object","description":"Fields to update"}},"required":["where","data"]}
ACTION delete_where DESCRIPTION "Delete rows matching conditions" SCHEMA {"type":"object","properties":{"where":{"type":"object","description":"Delete conditions (MongoDB-style operators)"}},"required":["where"]}
ACTION bulk_insert DESCRIPTION "Insert multiple rows at once" SCHEMA {"type":"object","properties":{"rows":{"type":"array","items":{"type":"object"},"minItems":1,"description":"Array of row data to insert"}},"required":["rows"]}
ACTION import DESCRIPTION "Import data into table from JSON or CSV format" SCHEMA {"type":"object","properties":{"format":{"type":"string","enum":["json","csv"],"description":"Data format (json or csv)"},"data":{"type":"string","description":"The data to import (JSON array string or CSV string)"},"onConflict":{"type":"string","enum":["abort","ignore","replace"],"default":"abort","description":"Conflict resolution strategy"},"delimiter":{"type":"string","default":",","description":"CSV delimiter character"},"header":{"type":"boolean","default":true,"description":"Whether CSV has a header row"}},"required":["format","data"]}"
`;

exports[`ls command .actions paths view=llm sqlite row actions (/sqlite/users/1/.actions): ls-llm-sqlite-users-1-_actions 1`] = `
"ACTIONS /sqlite/users/1/.actions
ACTION duplicate DESCRIPTION "Create a copy of this row" SCHEMA {"type":"object","description":"Create a copy of the row (excluding primary key \\"id\\")","properties":{},"additionalProperties":false,"x-copied-columns":["name","email","created_at"]}
ACTION validate DESCRIPTION "Validate row data against schema constraints" SCHEMA {"type":"object","description":"Validate row data against \\"users\\" table constraints","properties":{},"additionalProperties":false,"x-table-schema":{"columns":[{"name":"id","type":"INTEGER","nullable":true,"primaryKey":true},{"name":"name","type":"TEXT","nullable":false,"primaryKey":false},{"name":"email","type":"TEXT","nullable":true,"primaryKey":false},{"name":"created_at","type":"TEXT","nullable":true,"primaryKey":false}],"foreignKeys":[]}}
ACTION update DESCRIPTION "Update this row" SCHEMA {"type":"object","description":"Update fields in \\"users\\" table","properties":{"data":{"type":"object","description":"Fields to update","properties":{"name":{"type":"string"},"email":{"type":"string"},"created_at":{"type":"string"}},"additionalProperties":false}},"required":["data"]}
ACTION delete DESCRIPTION "Delete this row" SCHEMA {"type":"object","properties":{},"description":"Delete the current row"}"
`;

exports[`ls command .actions paths view=json sqlite root actions (/sqlite/.actions): ls-json-sqlite-_actions 1`] = `
"{
  "path": "/sqlite/.actions",
  "data": [
    {
      "name": "create_table",
      "description": "Create a new table in the database",
      "inputSchema": {
        "type": "object",
        "description": "Create a new SQLite table with specified columns",
        "properties": {
          "name": {
            "type": "string",
            "description": "Table name (alphanumeric and underscores, must start with letter)",
            "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$",
            "minLength": 1,
            "maxLength": 128
          },
          "columns": {
            "type": "array",
            "description": "Column definitions (at least one required)",
            "minItems": 1,
            "items": {
              "type": "object",
              "description": "Column definition",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Column name (alphanumeric and underscores)",
                  "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
                  "minLength": 1,
                  "maxLength": 128
                },
                "type": {
                  "type": "string",
                  "description": "SQLite column type",
                  "enum": [
                    "INTEGER",
                    "TEXT",
                    "REAL",
                    "BLOB",
                    "NUMERIC",
                    "INT",
                    "TINYINT",
                    "SMALLINT",
                    "MEDIUMINT",
                    "BIGINT",
                    "UNSIGNED BIG INT",
                    "INT2",
                    "INT8",
                    "CHARACTER",
                    "VARCHAR",
                    "VARYING CHARACTER",
                    "NCHAR",
                    "NATIVE CHARACTER",
                    "NVARCHAR",
                    "CLOB",
                    "DOUBLE",
                    "DOUBLE PRECISION",
                    "FLOAT",
                    "DECIMAL",
                    "BOOLEAN",
                    "DATE",
                    "DATETIME",
                    "TIMESTAMP"
                  ],
                  "x-affinity-mapping": {
                    "INTEGER": [
                      "INTEGER",
                      "INT",
                      "TINYINT",
                      "SMALLINT",
                      "MEDIUMINT",
                      "BIGINT",
                      "UNSIGNED BIG INT",
                      "INT2",
                      "INT8"
                    ],
                    "TEXT": [
                      "TEXT",
                      "CHARACTER",
                      "VARCHAR",
                      "VARYING CHARACTER",
                      "NCHAR",
                      "NATIVE CHARACTER",
                      "NVARCHAR",
                      "CLOB"
                    ],
                    "REAL": [
                      "REAL",
                      "DOUBLE",
                      "DOUBLE PRECISION",
                      "FLOAT"
                    ],
                    "NUMERIC": [
                      "NUMERIC",
                      "DECIMAL",
                      "BOOLEAN",
                      "DATE",
                      "DATETIME",
                      "TIMESTAMP"
                    ],
                    "BLOB": [
                      "BLOB"
                    ]
                  }
                },
                "nullable": {
                  "type": "boolean",
                  "description": "Whether the column allows NULL values (default: true)",
                  "default": true
                },
                "primaryKey": {
                  "type": "boolean",
                  "description": "Whether this column is the primary key (default: false). INTEGER PRIMARY KEY will auto-increment.",
                  "default": false
                },
                "unique": {
                  "type": "boolean",
                  "description": "Whether this column must have unique values (default: false)",
                  "default": false
                },
                "defaultValue": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "boolean"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "description": "Default value for the column. Use string 'CURRENT_TIMESTAMP' for auto timestamp."
                },
                "references": {
                  "type": "object",
                  "description": "Foreign key reference",
                  "properties": {
                    "table": {
                      "type": "string",
                      "description": "Referenced table name"
                    },
                    "column": {
                      "type": "string",
                      "description": "Referenced column name"
                    },
                    "onDelete": {
                      "type": "string",
                      "enum": [
                        "CASCADE",
                        "SET NULL",
                        "SET DEFAULT",
                        "RESTRICT",
                        "NO ACTION"
                      ],
                      "description": "Action on delete (default: NO ACTION)"
                    },
                    "onUpdate": {
                      "type": "string",
                      "enum": [
                        "CASCADE",
                        "SET NULL",
                        "SET DEFAULT",
                        "RESTRICT",
                        "NO ACTION"
                      ],
                      "description": "Action on update (default: NO ACTION)"
                    }
                  },
                  "required": [
                    "table",
                    "column"
                  ]
                }
              },
              "required": [
                "name",
                "type"
              ],
              "additionalProperties": false
            }
          },
          "ifNotExists": {
            "type": "boolean",
            "description": "If true, do not throw error if table already exists (default: false)",
            "default": false
          }
        },
        "required": [
          "name",
          "columns"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "drop_table",
      "description": "Drop a table from the database",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Table name to drop"
          },
          "ifExists": {
            "type": "boolean",
            "default": false,
            "description": "Don't error if table doesn't exist"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "rename_table",
      "description": "Rename a table in the database",
      "inputSchema": {
        "type": "object",
        "properties": {
          "oldName": {
            "type": "string",
            "description": "Current table name"
          },
          "newName": {
            "type": "string",
            "description": "New table name"
          }
        },
        "required": [
          "oldName",
          "newName"
        ]
      }
    },
    {
      "name": "pragma",
      "description": "Execute a PRAGMA command (whitelist-restricted)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "table_info",
              "table_list",
              "index_list",
              "index_info",
              "foreign_key_list",
              "database_list",
              "collation_list",
              "journal_mode",
              "synchronous",
              "cache_size",
              "page_size",
              "encoding",
              "auto_vacuum",
              "integrity_check",
              "quick_check"
            ],
            "description": "PRAGMA command to execute"
          },
          "argument": {
            "type": "string",
            "description": "Argument for the command (e.g., table name)"
          },
          "value": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
