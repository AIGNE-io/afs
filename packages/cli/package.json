{
  "name": "@aigne/afs-cli",
  "version": "1.11.0-beta.13",
  "description": "AFS Command Line Interface",
  "license": "BUSL-1.1",
  "publishConfig": {
    "access": "public"
  },
  "author": "Arcblock <blocklet@arcblock.io> https://github.com/arcblock",
  "homepage": "https://github.com/arcblock/afs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcblock/afs"
  },
  "bugs": {
    "url": "https://github.com/arcblock/afs/issues"
  },
  "type": "module",
  "bin": {
    "afs": "./dist/cli.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./cli": {
      "require": "./dist/cli.cjs",
      "import": "./dist/cli.mjs"
    },
    "./core": {
      "require": "./dist/core/index.cjs",
      "import": "./dist/core/index.mjs"
    },
    "./*": "./*"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "prepublishOnly": "run-s clean build",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text"
  },
  "dependencies": {
    "@aigne/afs": "workspace:*",
    "@aigne/afs-explorer": "workspace:*",
    "@aigne/afs-fs": "workspace:*",
    "@aigne/afs-git": "workspace:*",
    "@aigne/afs-json": "workspace:*",
    "@aigne/afs-sqlite": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "blessed": "^0.1.81",
    "smol-toml": "^1.3.1",
    "ufo": "^1.6.3",
    "urlpattern-polyfill": "^10.1.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "yargs": "^17.7.2",
    "yargs-parser": "^22.0.0",
    "zod": "^4.0.0"
  },
  "optionalDependencies": {
    "@aigne/afs-http": "workspace:*",
    "@aigne/afs-mcp": "workspace:*",
    "@aigne/afs-toml": "workspace:*",
    "@aigne/afs-ui": "workspace:*",
    "remark-directive": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@aigne/scripts": "workspace:*",
    "@aigne/typescript-config": "workspace:*",
    "@modelcontextprotocol/server-everything": "^2026.1.26",
    "@types/blessed": "^0.1.25",
    "@types/bun": "^1.3.6",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.33",
    "@types/yargs-parser": "^21.0.3",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.2",
    "tsdown": "0.20.0-beta.3",
    "typescript": "5.9.2"
  }
}
