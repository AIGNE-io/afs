{
  "name": "@aigne/afs",
  "version": "1.11.0-beta.13",
  "description": "Agentic File System (AFS) is a virtual file system that supports various storage backends and provides a unified API for file operations.",
  "license": "BUSL-1.1",
  "publishConfig": {
    "access": "public"
  },
  "author": "Arcblock <blocklet@arcblock.io> https://github.com/arcblock",
  "homepage": "https://github.com/arcblock/afs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcblock/afs"
  },
  "bugs": {
    "url": "https://github.com/arcblock/afs/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./loader": {
      "require": "./dist/loader/index.cjs",
      "import": "./dist/loader/index.mjs"
    },
    "./provider": {
      "require": "./dist/provider/index.cjs",
      "import": "./dist/provider/index.mjs"
    },
    "./utils/camelize": {
      "require": "./dist/utils/camelize.cjs",
      "import": "./dist/utils/camelize.mjs"
    },
    "./utils/patch": {
      "require": "./dist/utils/patch.cjs",
      "import": "./dist/utils/patch.mjs"
    },
    "./utils/schema": {
      "require": "./dist/utils/schema.cjs",
      "import": "./dist/utils/schema.mjs"
    },
    "./utils/type-utils": {
      "require": "./dist/utils/type-utils.cjs",
      "import": "./dist/utils/type-utils.mjs"
    },
    "./utils/uri": {
      "require": "./dist/utils/uri.cjs",
      "import": "./dist/utils/uri.mjs"
    },
    "./utils/uri-template": {
      "require": "./dist/utils/uri-template.cjs",
      "import": "./dist/utils/uri-template.mjs"
    },
    "./utils/zod": {
      "require": "./dist/utils/zod.cjs",
      "import": "./dist/utils/zod.mjs"
    },
    "./*": "./*"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "prepublishOnly": "run-s clean build",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text"
  },
  "dependencies": {
    "@aigne/uuid": "^13.0.1",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.0.9",
    "minimatch": "^10.2.3",
    "strict-event-emitter": "^0.5.1",
    "ufo": "^1.6.3",
    "yaml": "^2.8.2",
    "zod": "^4.0.0",
    "zod-validation-error": "^4.0.0"
  },
  "optionalDependencies": {
    "@aigne/afs-trust": "workspace:*"
  },
  "devDependencies": {
    "@aigne/scripts": "workspace:*",
    "@aigne/typescript-config": "workspace:*",
    "@types/bun": "^1.3.6",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.2",
    "tsdown": "0.20.0-beta.3",
    "typescript": "5.9.2"
  }
}
